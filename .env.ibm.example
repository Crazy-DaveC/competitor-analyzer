# IBM Cloud Environment Variables
# Copy this file to .env.ibm and fill in your actual values
# DO NOT commit .env.ibm to version control

# IBM watsonx.ai Configuration
WATSONX_API_KEY=your_ibm_watsonx_api_key_here
WATSONX_SPACE_ID=your_watsonx_space_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Note: These variables should be set in IBM Cloud using:
# ibmcloud cf set-env competitor-analyzer-ibm WATSONX_API_KEY "your_key"
# ibmcloud cf set-env competitor-analyzer-ibm WATSONX_SPACE_ID "your_space_id"
# ibmcloud cf set-env competitor-analyzer-ibm WATSONX_URL "https://us-south.ml.cloud.ibm.com"